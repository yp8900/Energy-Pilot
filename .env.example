# BMS Multi-Vendor Integration Configuration Examples
# Copy this file to .env and modify according to your setup

# === Schneider EcoStruxure Example ===
BMS_CONFIG_SCHNEIDER='[{
  "id": "schneider_main",
  "name": "Schneider EcoStruxure Main Building",
  "vendor": "schneider",
  "database": {
    "server": "schneider-server.company.com",
    "port": 1433,
    "database": "EcoStruxure_Main",
    "user": "ems_reader",
    "password": "your_password_here",
    "options": {
      "trustServerCertificate": true,
      "encrypt": false
    }
  },
  "sync": {
    "enableRealtime": true,
    "intervalMinutes": 2
  },
  "customMappings": {}
}]'

# === Siemens Navigator Example ===
BMS_CONFIG_SIEMENS='[{
  "id": "siemens_west",
  "name": "Siemens Navigator West Wing",
  "vendor": "siemens",
  "database": {
    "server": "siemens-nav.company.com",
    "port": 1433,
    "database": "Navigator_WestWing",
    "user": "ems_reader",
    "password": "your_password_here"
  },
  "sync": {
    "enableRealtime": true,
    "intervalMinutes": 3
  }
}]'

# === File-Based Data Source Example ===
BMS_CONFIG_FILES='[{
  "id": "csv_import",
  "name": "CSV Data Import",
  "vendor": "file",
  "fileConfig": {
    "format": "csv",
    "metersFile": "C:/BMS_Data/devices.csv",
    "readingsFile": "C:/BMS_Data/readings.csv",
    "alarmsFile": "C:/BMS_Data/alarms.csv",
    "csvOptions": {
      "delimiter": ",",
      "hasHeaders": true,
      "skipRows": 0
    },
    "fieldMappings": {
      "meters": {
        "id": "DeviceID",
        "name": "DeviceName",
        "type": "DeviceType",
        "location": "Location",
        "isOnline": "Status",
        "lastSeen": "LastUpdate"
      },
      "readings": {
        "meterId": "DeviceID",
        "timestamp": "ReadingTime",
        "activePower": "Power_kW",
        "voltage": {
          "L1": "Voltage_L1",
          "L2": "Voltage_L2", 
          "L3": "Voltage_L3"
        },
        "current": {
          "L1": "Current_L1",
          "L2": "Current_L2",
          "L3": "Current_L3"
        },
        "energy": "Energy_kWh",
        "frequency": "Frequency",
        "powerFactor": "PF"
      },
      "alarms": {
        "id": "AlarmID",
        "meterId": "DeviceID",
        "message": "AlarmText",
        "severity": "Priority",
        "isActive": "Active",
        "timestamp": "AlarmTime"
      }
    },
    "refreshIntervalSeconds": 60,
    "watchForChanges": true
  },
  "sync": {
    "enableRealtime": false,
    "intervalMinutes": 5
  }
}]'

# === Multi-System Setup Example ===
# You can combine multiple systems by setting multiple config variables
BMS_CONFIG_PRIMARY='[
  {
    "id": "schneider_main",
    "name": "Schneider Main Building",
    "vendor": "schneider",
    "database": {
      "server": "main-bms.company.com",
      "database": "EcoStruxure_Main",
      "user": "ems_reader",
      "password": "password1"
    },
    "sync": {"enableRealtime": true, "intervalMinutes": 2}
  },
  {
    "id": "siemens_west",
    "name": "Siemens West Wing", 
    "vendor": "siemens",
    "database": {
      "server": "west-bms.company.com",
      "database": "Navigator_West",
      "user": "ems_reader",
      "password": "password2"
    },
    "sync": {"enableRealtime": true, "intervalMinutes": 3}
  }
]'

# === Development/Testing Configuration ===
BMS_CONFIG_DEV='[{
  "id": "dev_simulator",
  "name": "Development Data Simulator",
  "vendor": "file",
  "fileConfig": {
    "format": "json",
    "metersFile": "./data/dev_meters.json",
    "readingsFile": "./data/dev_readings.json",
    "alarmsFile": "./data/dev_alarms.json",
    "fieldMappings": {
      "meters": {
        "id": "id",
        "name": "name",
        "type": "type",
        "location": "location",
        "isOnline": "online",
        "lastSeen": "lastSeen"
      },
      "readings": {
        "meterId": "deviceId",
        "timestamp": "timestamp",
        "activePower": "activePower",
        "voltage": "voltage",
        "current": "current",
        "energy": "energy",
        "frequency": "frequency",
        "powerFactor": "powerFactor"
      }
    }
  },
  "sync": {"enableRealtime": false, "intervalMinutes": 10}
}]'

# === Production Settings ===
NODE_ENV=production
PORT=5000

# === Optional: Database for Internal Storage ===
DATABASE_URL=postgresql://user:password@localhost:5432/ems_db

# === Optional: Legacy BMS Support ===
# Keep these for backward compatibility with existing single BMS setup
BMS_SERVER=legacy-bms.company.com
BMS_DATABASE=LegacyBMS
BMS_USER=legacy_user
BMS_PASSWORD=legacy_password